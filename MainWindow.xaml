<Window
    x:Class="GameStoreApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vistas="using:GameStoreApp.Views"
    Title="Gaura">

    <Grid Background="{StaticResource LightGrayBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryBlueBrush}" Padding="24,0"
                BorderBrush="#1a2c3d" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Spacing="12">
                    <Border Width="54" Height="54" CornerRadius="8"
                            Background="Transparent">
                        <Image Source="ms-appx:///Assets/gauraLOGO.png"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Gaura" FontSize="22" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"
                               CharacterSpacing="20"/>
                </StackPanel>

                <StackPanel x:Name="PanelBotonesNavegacion" Grid.Column="1"
                            Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center" Spacing="2" Visibility="Collapsed">
                    <Button x:Name="BotonNavTienda" Style="{StaticResource NavButtonStyle}"
                            Click="BotonNavTienda_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE719;" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Tienda" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BotonNavPerfil" Style="{StaticResource NavButtonStyle}"
                            Click="BotonNavPerfil_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE77B;" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Perfil" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BotonNavAdmin" Style="{StaticResource NavButtonStyle}"
                            Visibility="Collapsed" Click="BotonNavAdmin_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE713;" FontSize="15" VerticalAlignment="Center"/>
                            <TextBlock Text="Admin" VerticalAlignment="Center" FontSize="15"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel x:Name="PanelUsuario" Grid.Column="2"
                            Orientation="Horizontal" VerticalAlignment="Center"
                            Spacing="4" Visibility="Collapsed">
                    <Border CornerRadius="16" Background="#3d7ab5"
                            Padding="12,6" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="White"
                                      VerticalAlignment="Center"/>
                            <Button x:Name="BotonUsuarioActual"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" CornerRadius="0" Foreground="White"
                                    Click="BotonUsuarioActual_Click">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="White"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="White"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                </Button.Resources>
                                <TextBlock x:Name="TxtNombreUsuarioActual"
                                           Foreground="White" FontSize="15"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                    <Button x:Name="BotonCerrarSesion"
                            Background="Transparent" BorderThickness="0"
                            Padding="12,8" CornerRadius="6" Foreground="White"
                            Click="BotonCerrarSesion_Click">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#c0392b"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#a93226"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="White"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="White"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <FontIcon Glyph="&#xE7E8;" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Cerrar Sesión" FontSize="15" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContenedorVistas" Grid.Row="1">
            <vistas:LoginView      x:Name="VistaInicioSesion"  Visibility="Visible"/>
            <vistas:RegisterView   x:Name="VistaRegistro"      Visibility="Collapsed"/>
            <vistas:StoreView      x:Name="VistaTienda"        Visibility="Collapsed"/>
            <vistas:GameDetailView x:Name="VistaDetalleJuego"  Visibility="Collapsed"/>
            <vistas:ProfileView    x:Name="VistaPerfil"        Visibility="Collapsed"/>
            <vistas:AdminView      x:Name="VistaAdmin"         Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
