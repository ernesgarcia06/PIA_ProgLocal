<UserControl
    x:Class="GameStoreApp.Views.GameDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource LightGrayBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource WhiteBrush}" Padding="16,10"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Button x:Name="BtnBack" Style="{StaticResource BackButtonStyle}" Click="BtnBack_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTextoRegresar"
                               Text="Volver a la Tienda" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" Padding="24,20,12,20">
                <StackPanel Spacing="20" MaxWidth="800">

                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="GameBanner" Grid.Column="0"
                                    Height="200" Width="240" CornerRadius="8"
                                    Margin="0,0,20,0" Padding="8" VerticalAlignment="Top">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                                    <FontIcon x:Name="GameCategoryIcon" FontSize="52" Foreground="White"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtGameCategoryBadge" FontSize="13"
                                               Foreground="White" HorizontalAlignment="Center" Opacity="0.9"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Grid.Column="1" Spacing="12">
                                <TextBlock x:Name="TxtGameName" Style="{StaticResource H1Style}"
                                           FontSize="24" TextWrapping="Wrap"/>

                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE787;" FontSize="14"
                                                  Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtGameYear" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE8EC;" FontSize="14"
                                                  Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtGameCategory" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel x:Name="RatingDisplay" Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE735;" FontSize="14" Foreground="#F59E0B" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtGameRating" Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <TextBlock x:Name="TxtGameDescription" FontSize="14"
                                           Foreground="{StaticResource DarkTextBrush}"
                                           TextWrapping="Wrap" LineHeight="22" TextAlignment="Justify"/>

                                <TextBlock x:Name="TxtGamePrice" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBlueBrush}"/>

                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                                    <Button x:Name="BtnWishlist" Style="{StaticResource SecondaryButtonStyle}"
                                            Click="BtnWishlist_Click"/>
                                    <Button x:Name="BtnBuy" Style="{StaticResource PrimaryButtonStyle}" Click="BtnBuy_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE7BF;" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Comprar ahora" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <Border x:Name="PurchasedBadge" Background="#E8F5E9"
                                        CornerRadius="8" Padding="12,8" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE930;" FontSize="14"
                                                  Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ya tienes este juego" FontSize="13"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border x:Name="PanelFormularioResenia" Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE932;" FontSize="18" Foreground="{StaticResource PrimaryBlueBrush}"/>
                                <TextBlock Text="Tu Reseña" Style="{StaticResource H2Style}" FontSize="17"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Calificación:" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <StackPanel x:Name="StarPanel" Orientation="Horizontal" Spacing="4"/>
                            </StackPanel>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Comentario:" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                                <TextBox x:Name="TxtReviewText" Style="{StaticResource AppTextBoxStyle}"
                                         PlaceholderText="Escribe tu opinión sobre este juego..."
                                         AcceptsReturn="True" Height="90" TextWrapping="Wrap" MaxLength="500"/>
                            </StackPanel>
                            <Button x:Name="BtnSubmitReview" Style="{StaticResource PrimaryButtonStyle}"
                                    Click="BtnSubmitReview_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE725;" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Publicar Reseña" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Border x:Name="ReviewStatusBorder" Visibility="Collapsed" CornerRadius="8" Padding="10,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon x:Name="ReviewStatusIcon" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtReviewStatus" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PanelReseniaNoDisponible"
                            Style="{StaticResource CardStyle}"
                            Visibility="Collapsed">
                        <StackPanel Spacing="12" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Padding="0,8">
                            <FontIcon Glyph="&#xE72E;" FontSize="28"
                                      Foreground="{StaticResource SecondaryTextBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="Solo puedes reseñar juegos que hayas comprado"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8F2;" FontSize="18" Foreground="{StaticResource PrimaryBlueBrush}"/>
                            <TextBlock Text="Reseñas de la comunidad" Style="{StaticResource H2Style}" FontSize="17"/>
                        </StackPanel>
                        <StackPanel x:Name="ReviewsEmptyState" Visibility="Collapsed"
                                    HorizontalAlignment="Center" Spacing="8">
                            <FontIcon Glyph="&#xE8F2;" FontSize="36"
                                      Foreground="{StaticResource MediumGrayBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="Aún no hay reseñas. ¡Sé el primero!"
                                       Style="{StaticResource SecondaryTextStyle}" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel x:Name="ReviewsPanel" Spacing="10"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" Padding="12,20,24,20"
                          VerticalScrollBarVisibility="Auto">
                <Border Style="{StaticResource CardStyle}" Padding="20">
                    <StackPanel Spacing="16">

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE8B9;" FontSize="18"
                                      Foreground="{StaticResource PrimaryBlueBrush}"/>
                            <TextBlock Text="Fotos" Style="{StaticResource H2Style}" FontSize="17"/>
                            <TextBlock x:Name="TxtPhotosCount"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource MediumGrayBrush}"/>

                        <StackPanel x:Name="FotosVaciaPlaceholder"
                                    HorizontalAlignment="Center" Spacing="12"
                                    Margin="0,30,0,30">
                            <FontIcon Glyph="&#xE8B9;" FontSize="56"
                                      Foreground="{StaticResource MediumGrayBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="Sin fotos disponibles"
                                       Style="{StaticResource SecondaryTextStyle}"
                                       HorizontalAlignment="Center" FontSize="14"/>
                        </StackPanel>

                        <Border x:Name="VisorFotoBorder"
                                CornerRadius="12"
                                Background="{StaticResource LightGrayBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                Height="360"
                                Visibility="Collapsed">
                            <Image x:Name="ImgVisorFoto"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        </Border>

                        <ItemsRepeater x:Name="GaleriaMiniaturasPanel">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="120" MinItemHeight="120"
                                                   MinColumnSpacing="8" MinRowSpacing="8"/>
                            </ItemsRepeater.Layout>
                        </ItemsRepeater>

                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
