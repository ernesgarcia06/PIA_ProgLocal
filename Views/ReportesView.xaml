<UserControl
    x:Class="GameStoreApp.Views.ReportesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource LightGrayBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,1,0">
            <ScrollViewer Padding="16,20,16,20">
                <StackPanel Spacing="16">

                    <TextBlock Text="Filtros del reporte"
                               Style="{StaticResource H2Style}" FontSize="16"/>
                    <Border Height="1" Background="{StaticResource MediumGrayBrush}"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Tipo de reporte" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CmbTipoReporte"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="CmbTipoReporte_Changed">
                            <ComboBoxItem Content="Más comprados"     IsSelected="True"/>
                            <ComboBoxItem Content="Más deseados"/>
                            <ComboBoxItem Content="Más reseñados"/>
                            <ComboBoxItem Content="Calificaciones"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Período" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CmbPeriodo"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="CmbPeriodo_Changed">
                            <ComboBoxItem Content="Desde siempre" IsSelected="True"/>
                            <ComboBoxItem Content="Mes específico"/>
                            <ComboBoxItem Content="Rango de meses"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel x:Name="PanelMesEspecifico" Spacing="6" Visibility="Collapsed">
                        <TextBlock Text="Mes y año" Style="{StaticResource LabelStyle}"/>
                        <CalendarDatePicker x:Name="FechaMesEspecifico"
                                            HorizontalAlignment="Stretch"
                                            PlaceholderText="Selecciona fecha"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelRangoFechas" Spacing="8" Visibility="Collapsed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Desde" Style="{StaticResource LabelStyle}"/>
                            <CalendarDatePicker x:Name="FechaDesde"
                                                HorizontalAlignment="Stretch"
                                                PlaceholderText="Fecha inicio"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Hasta" Style="{StaticResource LabelStyle}"/>
                            <CalendarDatePicker x:Name="FechaHasta"
                                                HorizontalAlignment="Stretch"
                                                PlaceholderText="Fecha fin"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Categoría" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CmbCategoria"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="Todas las categorías"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelPrecio" Spacing="6">
                        <TextBlock Text="Filtro de precio" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CmbOperadorPrecio"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="CmbOperadorPrecio_SelectionChanged">
                            <ComboBoxItem Content="Sin filtro de precio" IsSelected="True"/>
                            <ComboBoxItem Content="Igual a"/>
                            <ComboBoxItem Content="Mayor que"/>
                            <ComboBoxItem Content="Menor que"/>
                        </ComboBox>
                        <TextBox x:Name="TxtPrecio"
                                 PlaceholderText="Ej: 500"
                                 MaxLength="7"
                                 TextChanged="TxtPrecio_TextChanged"
                                 Visibility="Collapsed"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelCalificaciones" Spacing="8" Visibility="Collapsed">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Ordenar" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="CmbOrdenCalif"
                                      HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Mejores primero" IsSelected="True"/>
                                <ComboBoxItem Content="Peores primero"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Estrellas mínimas" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="CmbEstrellaMin" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="1" IsSelected="True"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Estrellas máximas" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="CmbEstrellaMax" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5" IsSelected="True"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Margin="0,8,0,0"
                            Click="BtnGenerarReporte_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE9F9;" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Generar reporte" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="BtnLimpiarFiltros_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE894;" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="Limpiar filtros" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock x:Name="TxtErrorFiltro"
                               Foreground="{StaticResource ErrorBrush}"
                               FontSize="12" TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="0,0,0,1" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="TxtTituloReporte"
                                   Text="Selecciona un tipo de reporte y genera"
                                   Style="{StaticResource H2Style}" FontSize="17"/>
                        <TextBlock x:Name="TxtSubtituloReporte"
                                   Text="Configura los filtros y presiona Generar"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Spacing="8" VerticalAlignment="Center">
                        <Button x:Name="BtnExportarPDF"
                                Visibility="Collapsed"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="BtnExportarPDF_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74E;" FontSize="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar PDF" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        <Border Background="#EFF6FF"
                                CornerRadius="20"
                                Padding="14,6"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="TxtConteoResultados"
                                       Text="—"
                                       Foreground="{StaticResource PrimaryBlueBrush}"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="20,16">
                <StackPanel Spacing="0">

                    <StackPanel x:Name="EstadoInicial"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="14" Margin="0,80,0,0">
                        <FontIcon Glyph="&#xE9F9;" FontSize="56"
                                  Foreground="{StaticResource MediumGrayBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Configura los filtros y presiona"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Generar reporte"
                                   Foreground="{StaticResource PrimaryBlueBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="EstadoSinResultados"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                Spacing="10" Margin="0,80,0,0">
                        <FontIcon Glyph="&#xE721;" FontSize="48"
                                  Foreground="{StaticResource MediumGrayBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="Sin resultados con estos filtros"
                                   Style="{StaticResource SecondaryTextStyle}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelResultados" Spacing="8" Visibility="Collapsed"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
