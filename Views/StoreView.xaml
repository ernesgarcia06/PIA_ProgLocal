<UserControl
    x:Class="GameStoreApp.Views.StoreView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource LightGrayBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="28,18,28,16"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="Tienda" Style="{StaticResource H1Style}"/>
                    <TextBlock x:Name="TxtGameCount" Style="{StaticResource SecondaryTextStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="28,12,28,12"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="10">

                    <Grid Height="38">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtSearch" Grid.Column="0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 PlaceholderText="Buscar juego..."
                                 MaxLength="60"
                                 VerticalAlignment="Stretch"
                                 CornerRadius="8,0,0,8"
                                 TextChanged="TxtSearch_TextChanged"/>
                        <Button x:Name="BtnSearch" Grid.Column="1"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Height="38" Width="42"
                                Padding="0" CornerRadius="0,8,8,0"
                                Click="BtnSearch_Click">
                            <FontIcon Glyph="&#xE721;" FontSize="14"/>
                        </Button>
                    </Grid>

                    <ComboBox x:Name="CmbCategory" Style="{StaticResource AppComboBoxStyle}"
                              PlaceholderText="Categoría" SelectionChanged="Filter_Changed"/>
                    <ComboBox x:Name="CmbYear" Style="{StaticResource AppComboBoxStyle}"
                              PlaceholderText="Año" Width="100" SelectionChanged="Filter_Changed"/>
                    <ComboBox x:Name="CmbSort" Style="{StaticResource AppComboBoxStyle}"
                              SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="A-Z" IsSelected="True"/>
                        <ComboBoxItem Content="Z-A"/>
                        <ComboBoxItem Content="Precio ↑"/>
                        <ComboBoxItem Content="Precio ↓"/>
                        <ComboBoxItem Content="Año ↑"/>
                        <ComboBoxItem Content="Año ↓"/>
                    </ComboBox>

                    <Button Padding="12,8" Click="BtnClearFilters_Click"
                            Background="Transparent" BorderThickness="1.5"
                            CornerRadius="8" FontSize="13">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#d8dce3"/>
                            <SolidColorBrush x:Key="ButtonForeground"             Color="#24384c"/>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#24384c"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="White"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#24384c"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#1a2c3d"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="White"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="#1a2c3d"/>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE894;" FontSize="12"/>
                            <TextBlock Text="Limpiar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer Grid.Row="2" Padding="24,20,24,24">
            <StackPanel Spacing="0" HorizontalAlignment="Center">
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            HorizontalAlignment="Center" Margin="0,80,0,0" Spacing="16">
                    <FontIcon Glyph="&#xE721;" FontSize="52"
                              Foreground="{StaticResource MediumGrayBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="No se encontraron juegos"
                               Style="{StaticResource H2Style}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Intenta con otros filtros o términos de búsqueda."
                               Style="{StaticResource SecondaryTextStyle}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <ItemsRepeater x:Name="GamesRepeater"
                               HorizontalAlignment="Center">
                    <ItemsRepeater.Layout>
                        <UniformGridLayout MinItemWidth="230" MinItemHeight="310"
                                           MinColumnSpacing="16" MinRowSpacing="16"/>
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
